# ==============================================================================
# Zênite PDV — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores para seu ambiente.
# NUNCA faça commit do arquivo .env real no repositório.
# ==============================================================================

# ------------------------------------------------------------------------------
# Banco de Dados (PostgreSQL)
# DEV local:      postgresql://zenite:zenite_dev_pass@localhost:55432/zenite_pdv
# Neon (staging): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#   ↳ Cole a URL do painel Neon → Project → Connection Details → Connection string
#   ↳ O backend converte sslmode=require → ssl=require para asyncpg automaticamente
# Railway (auto): o Railway injeta DATABASE_URL automaticamente ao linkar o plugin
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://zenite:zenite_dev_pass@localhost:55432/zenite_pdv

# Pool de conexões
# Neon free tier suporta ~10 conexões simultâneas — use valores baixos em staging
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ------------------------------------------------------------------------------
# Redis
# DEV local:      redis://localhost:6379/0
# Railway (auto): o Railway injeta REDIS_URL automaticamente ao linkar o plugin
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# Segurança / JWT
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# OBRIGATÓRIO: use valor diferente por ambiente (dev / staging / prod)
# ------------------------------------------------------------------------------
SECRET_KEY=TROQUE_ESTA_CHAVE_EM_PRODUCAO_gere_um_valor_aleatorio_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ------------------------------------------------------------------------------
# Aplicação
# Valores válidos para APP_ENV: development | staging | production
# Em production: /docs e /openapi.json ficam desativados automaticamente
# ------------------------------------------------------------------------------
APP_NAME="Zênite PDV"
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# CORS
# DEV:      ["http://localhost:5173","http://localhost:3000"]
# Staging:  ["https://zenite-pdv-staging.vercel.app"]
# Prod:     ["https://zenite-pdv.vercel.app","https://pdv.seudominio.com.br"]
# Formato:  JSON array em string — pydantic-settings faz o parse automaticamente
# ------------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ------------------------------------------------------------------------------
# Fiscal — Provedor externo (Focus NFe / PlugNotas / etc.)
# As chaves de API são configuradas por empresa no banco de dados.
# Esta variável define o provedor padrão para novas empresas.
# ------------------------------------------------------------------------------
FISCAL_PROVIDER_DEFAULT=focus_nfe

# Token da API Focus NFe (deixe vazio para usar MockFiscalGateway em dev)
# Homologação: obtenha em https://app.focusnfe.com.br
FOCUS_NFE_TOKEN=

# URL base do Focus NFe
# Homologação: https://homologacao.focusnfe.com.br
# Produção:    https://api.focusnfe.com.br
FOCUS_NFE_BASE_URL=https://homologacao.focusnfe.com.br

# Timeout em segundos para chamadas ao provedor fiscal
FOCUS_NFE_TIMEOUT=30

# Máximo de tentativas antes de marcar o documento como ERRO permanente
FISCAL_MAX_TENTATIVAS=5
