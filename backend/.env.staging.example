# ==============================================================================
# Zênite PDV — Variáveis de Ambiente de STAGING
#
# Este arquivo documenta as variáveis necessárias para o ambiente de staging:
#   - Backend rodando no Render (Web Service free)
#   - Worker rodando LOCALMENTE apontando para infra remota
#
# COMO USAR:
#   cp backend/.env.staging.example backend/.env.staging
#   # edite .env.staging com os valores reais (Neon URL, Render Redis URL, etc.)
#   # .env.staging está no .gitignore — nunca será commitado
#
# Para o backend no Render: configure estas variáveis no dashboard do serviço
# Para o worker local:      export as variáveis ou use o arquivo .env.staging
# ==============================================================================

# ------------------------------------------------------------------------------
# Banco de Dados (Neon)
# Obtenha em: Neon Console → Project → Connection Details → Connection string
# Formato psycopg2 (com sslmode=require) — o backend converte para asyncpg automaticamente
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-XXXX.us-east-2.aws.neon.tech/neondb?sslmode=require

# Pool de conexões reduzido para Neon free (máx ~10 conexões simultâneas)
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30

# ------------------------------------------------------------------------------
# Redis (Render managed Redis — URL externa com TLS)
# Obtenha em: Render Dashboard → zenite-pdv-redis → Info → External Connection URL
# ATENÇÃO: use a External URL (rediss://) para conexões fora do Render
#          use a Internal URL (redis://)  apenas para serviços DENTRO do Render
# Para o worker local: use a External URL (rediss://)
# Para o backend no Render: o render.yaml já injeta a Internal URL automaticamente
# ------------------------------------------------------------------------------
REDIS_URL=rediss://default:SENHA@HOSTNAME.render.com:6379

# ------------------------------------------------------------------------------
# Segurança / JWT
# Use o mesmo SECRET_KEY em todos os serviços do mesmo ambiente
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
# ------------------------------------------------------------------------------
SECRET_KEY=GERE_E_COLE_AQUI_token_hex_32_caracteres_minimo

# ------------------------------------------------------------------------------
# Aplicação
# ------------------------------------------------------------------------------
APP_ENV=staging
DEBUG=false
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# CORS (backend Render)
# Preencha após obter a URL do frontend no Vercel
# Formato: JSON array como string
# ------------------------------------------------------------------------------
CORS_ORIGINS=["https://SEU-PROJETO.vercel.app"]

# ------------------------------------------------------------------------------
# Fiscal — MockFiscalGateway ativado automaticamente quando FOCUS_NFE_TOKEN=""
#
# Como funciona o roteamento:
#   FOCUS_NFE_TOKEN vazio  → MockFiscalGateway (documentos "emitidos" ficticiamente)
#   FOCUS_NFE_TOKEN preenchido → FocusNFeGateway (emissão real/homologação)
#
# Em staging: deixe FOCUS_NFE_TOKEN vazio para usar o mock.
# O worker local vai processar os documentos PENDENTE e marcá-los como EMITIDA
# usando dados fictícios (chave_acesso, protocolo, xml mock).
# ------------------------------------------------------------------------------
FOCUS_NFE_TOKEN=
FOCUS_NFE_BASE_URL=https://homologacao.focusnfe.com.br
FOCUS_NFE_TIMEOUT=30
FISCAL_MAX_TENTATIVAS=5

# ==============================================================================
# WORKER LOCAL — como rodar
# ==============================================================================
#
# Pré-requisito: .venv ativo com dependências instaladas
#   cd "ZÊNITE PDV"
#   .venv\Scripts\Activate.ps1
#
# Opção A — carregar .env.staging automaticamente (recomendado):
#   cd backend
#   # Crie o arquivo .env com os valores de staging:
#   #   copy .env.staging .env   (Windows)
#   #   cp .env.staging .env     (Linux/Mac)
#   arq app.workers.fiscal_worker.WorkerSettings
#
# Opção B — passar variáveis inline no PowerShell:
#   $env:DATABASE_URL  = "postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"
#   $env:REDIS_URL     = "rediss://default:SENHA@HOST.render.com:6379"
#   $env:SECRET_KEY    = "sua_secret_key_de_staging"
#   $env:APP_ENV       = "staging"
#   $env:FOCUS_NFE_TOKEN = ""
#   cd backend
#   arq app.workers.fiscal_worker.WorkerSettings
#
# O worker vai:
#   1. Conectar ao Neon (DATABASE_URL)
#   2. Conectar ao Redis no Render (REDIS_URL)
#   3. Escutar a fila "arq:zenite_fiscal"
#   4. Processar documentos PENDENTE usando MockFiscalGateway (token vazio)
#   5. Atualizar status → EMITIDA com chave_acesso e protocolo fictícios
#
# Log esperado ao iniciar:
#   INFO  FiscalWorker: conexão DB inicializada
#   WARNING FOCUS_NFE_TOKEN não configurado — usando MockFiscalGateway
#   INFO  Starting worker for queue: arq:zenite_fiscal
# ==============================================================================
