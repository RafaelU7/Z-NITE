# Variáveis de ambiente do frontend Zênite PDV
# Copie este arquivo para .env.local e preencha os valores

# ------------------------------------------------------------------------------
# DEV (sem proxy explícito — o Vite proxy em vite.config.ts encaminha /v1)
# Não é necessário definir VITE_API_BASE_URL em desenvolvimento.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# STAGING (Vercel → Render)
# Configure esta variável no painel do Vercel:
#   Project → Settings → Environment Variables → Production
# Substitua pela URL gerada pelo Render para o serviço zenite-pdv-api
# (sem barra final, sem /v1)
# ------------------------------------------------------------------------------
# VITE_API_BASE_URL=https://zenite-pdv-api.onrender.com

# ------------------------------------------------------------------------------
# PRODUÇÃO
# ------------------------------------------------------------------------------
# VITE_API_BASE_URL=https://SEU-BACKEND-PRODUCAO.onrender.com

# ------------------------------------------------------------------------------
# Opcional — pré-preenche campos do login para estações fixas
# ------------------------------------------------------------------------------
# VITE_EMPRESA_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# VITE_CAIXA_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
